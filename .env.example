PORT=5000

# Comma-separated list of frontend origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173,https://www.learntelugunow.com

# Gmail account that sends mail. Use an App Password (not your normal password).
# https://myaccount.google.com/apppasswords  (2-Step Verification must be enabled)
GMAIL_USER=your.account@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Inbox that receives contact form submissions.
RECIPIENT_EMAIL=learntelugunowofficial@gmail.com
